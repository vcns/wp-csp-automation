# Normalise line endings to LF on commit; checkout as LF on all platforms.
* text=auto eol=lf

*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Binary files -- no conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.woff binary
*.woff2 binary
